# 环境变量示例
# 复制为 .env 后按需修改
# 提示：所有配置都可以在前端「设置」页面里改并立即生效，环境变量只是默认值

# HTTP 服务
DAGENT_HOST=127.0.0.1
DAGENT_PORT=8765

# LLM 默认值（建议在前端配置）
DAGENT_LLM_PROVIDER=ollama
DAGENT_LLM_MODEL=qwen2.5:7b
DAGENT_LLM_BASE_URL=http://127.0.0.1:11434/v1
DAGENT_LLM_API_KEY=sk-xxx
# DAGENT_LLM_TEMPERATURE=0.2

# 心跳 / 超时
DAGENT_HEARTBEAT_INTERVAL_SECONDS=10
DAGENT_WORKFLOW_TIMEOUT_SECONDS=600
DAGENT_MAX_RETRIES=2
